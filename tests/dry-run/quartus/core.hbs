namespace eval core-a {
  proc src {} {
    hbs::SetLib "lib_a"
    hbs::SetArgPrefix "FileAnalPrefix"
    hbs::SetArgsSuffix "FileAnalSuffix"
    hbs::AddFile a.vhd
  }
  hbs::Register
}

namespace eval core-b {
  proc src {} {
    hbs::AddDep core-a::src
    hbs::SetLib "lib_b"
    hbs::AddFile b.vhd
  }
  hbs::Register
}

namespace eval core-c {
  proc src {} {
    hbs::SetTool "quartus"
    hbs::SetDevice "10M50DAF484C7G"
    hbs::AddDep core-b::src
    hbs::AddFile c.v
    hbs::AddFile d.sv
    hbs::SetGeneric GEN 64
    hbs::AddPreElabCb hbs::SetArgPrefix "ElabArgPrefix"
    hbs::AddPreElabCb hbs::SetArgsSuffix "ElabArgsSuffix"
    hbs::AddPreSynthCb hbs::SetArgPrefix "SynthArgPrefix"
    hbs::AddPreSynthCb hbs::SetArgsSuffix "SynthArgsSuffix"
    hbs::SetTop "TopEntity"
    hbs::AddPreImplCb hbs::SetArgPrefix "ImplArgPrefix"
    hbs::AddPreImplCb hbs::SetArgsSuffix "ImplArgsSuffix"

    hbs::Run
  }
  hbs::Register
}
