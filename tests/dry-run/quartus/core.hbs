namespace eval core-a {
  proc src {} {
    hbs::SetLib "lib_a"
    hbs::SetArgPrefix "FileAnalPrefix"
    hbs::SetArgSuffix "FileAnalSuffix"
    hbs::AddFile a.vhd
  }
  hbs::Register
}

namespace eval core-b {
  proc src {} {
    hbs::AddDep core-a::src
    hbs::SetLib "lib_b"
    hbs::AddFile b.vhd
  }
  hbs::Register
}

namespace eval core-c {
  proc src {} {
    hbs::SetTool "quartus"
    hbs::SetDevice "10M50DAF484C7G"
    hbs::AddDep core-b::src
    hbs::AddFile c.v
    hbs::AddFile d.sv
    hbs::SetGeneric GEN 64
    hbs::AddPreElabCb hbs::SetArgPrefix "ElabArgPrefix"
    hbs::AddPreElabCb hbs::SetArgSuffix "ElabArgSuffix"
    hbs::AddPreSynthCb hbs::SetArgPrefix "SynthArgPrefix"
    hbs::AddPreSynthCb hbs::SetArgSuffix "SynthArgSuffix"
    hbs::SetTop "TopEntity"
    hbs::AddPreImplCb hbs::SetArgPrefix "ImplArgPrefix"
    hbs::AddPreImplCb hbs::SetArgSuffix "ImplArgSuffix"

    hbs::Run
  }
  hbs::Register
}
